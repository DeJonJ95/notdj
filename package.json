{
  "name": "notdj",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Touch-first DJ controller PWA for iPad Pro — Pioneer CDJ-3000 + DJM-A9 inspired",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "build:local": ".node\\node-v20.18.0-win-x64\\node.exe ./node_modules/vite/bin/vite.js build",
    "dev:local": ".node\\node-v20.18.0-win-x64\\node.exe ./node_modules/vite/bin/vite.js --host",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "wrangler": "^4.99.0"
  },
  "dependencies": {
    "jsmediatags": "^3.9.7"
  }
}
