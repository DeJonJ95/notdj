{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "proportfolio/portfolio-grid",
	"title": "Portfolio Grid",
	"description": "Display a responsive grid of portfolio projects with optional category filtering.",
	"icon": "portfolio",
	"category": "widgets",
	"keywords": [
		"portfolio",
		"projects",
		"grid",
		"gallery",
		"showcase"
	],
	"attributes": {
		"count": {
			"type": "number",
			"default": 6
		},
		"columns": {
			"type": "number",
			"default": 3,
			"minimum": 1,
			"maximum": 4
		},
		"category": {
			"type": "string",
			"default": ""
		},
		"showFilter": {
			"type": "boolean",
			"default": true
		},
		"orderby": {
			"type": "string",
			"default": "date"
		},
		"order": {
			"type": "string",
			"default": "DESC"
		},
		"featuredOnly": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"align": ["wide", "full"],
		"html": false,
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"editor_style": "proportfolio-block-editor",
	"render": "file:./render.php",
	"textdomain": "proportfolio-showcase"
}